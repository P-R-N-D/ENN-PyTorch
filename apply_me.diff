+def compute_batch_bytes_per_sample(obj: object) -> tuple[int | None, int]:
+    """Estimate per-sample bytes of a batched, nested structure.
+
+    This is used for coarse memory planning (e.g. dynamic batch/accum decisions).
+
+    Returns:
+        (batch_dim, bytes_per_sample)
+
+    Where:
+        - batch_dim is inferred from the first tensor's dim0 (if any)
+        - bytes_per_sample is computed by slicing the first element along dim0
+          (or reshaping scalars) and summing element_size * numel across all
+          nested tensors.
+    """
+
+    batch_dim: int | None = None
+    bytes_per_sample = 0
+    stack: list[object] = [obj]
+
+    while stack:
+        o = stack.pop()
+        if isinstance(o, torch.Tensor):
+            if o.numel() <= 0:
+                continue
+            b = int(o.shape[0]) if o.ndim >= 1 else 1
+            if batch_dim is None:
+                batch_dim = b
+            if o.ndim >= 1 and b > 0:
+                one = o[:1]
+            else:
+                one = o.reshape(1, -1)
+            bytes_per_sample += int(one.nelement()) * int(one.element_size())
+        elif isinstance(o, TensorDictBase):
+            stack.extend(list(o.values()))
+        elif isinstance(o, Mapping):
+            stack.extend(list(o.values()))
+        elif isinstance(o, (list, tuple)):
+            stack.extend(list(o))
+
+    if bytes_per_sample <= 0:
+        return (None, 0)
+    return (batch_dim, bytes_per_sample)
