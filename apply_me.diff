+# ---------------------------------------------------------------------------
+# OOM recovery helpers (used by runtime.main)
+# ---------------------------------------------------------------------------
+
+_OOM_RETRY_COUNT: Dict[object, int] = {}
+_OOM_RETRY_LOCK = Mutex()
+_SAMPLER_SCALE_LOG_LAST_S: Dict[object, float] = {}
+_SAMPLER_SCALE_LOG_LOCK = Mutex()
+
+
+def _oom_key(loader: object, phase: object, step: int) -> tuple[int, str, int]:
+    return (int(id(loader)), str(phase), int(step))
+
+
+def oom_retries(loader: object, phase: object, step: int) -> int:
+    key = _oom_key(loader, phase, int(step))
+    with _OOM_RETRY_LOCK:
+        cur = int(_OOM_RETRY_COUNT.get(key, 0)) + 1
+        _OOM_RETRY_COUNT[key] = int(cur)
+        return int(cur)
+
+
+def clear_oom_retries(loader: object, phase: object, step: int) -> None:
+    key = _oom_key(loader, phase, int(step))
+    with _OOM_RETRY_LOCK:
+        _OOM_RETRY_COUNT.pop(key, None)
+
+
+def oom_max_retries(phase: object) -> int:
+    ph = str(phase).strip().lower()
+    if ph == "train":
+        v = env_int(
+            "ENN_OOM_MAX_RETRIES_TRAIN",
+            env_int("ENN_OOM_MAX_RETRIES_PER_BATCH", 4),
+        )
+    elif ph in {"val", "valid", "validation"}:
+        v = env_int(
+            "ENN_OOM_MAX_RETRIES_VAL",
+            env_int("ENN_OOM_MAX_RETRIES_PER_BATCH", 2),
+        )
+    else:
+        v = env_int("ENN_OOM_MAX_RETRIES_PER_BATCH", 3)
+    return max(0, int(v))
+
+
+def is_batch_skippable(phase: object) -> bool:
+    ph = str(phase).strip().lower()
+    if ph == "train":
+        return env_bool("ENN_OOM_SKIP_TRAIN", env_bool("ENN_OOM_SKIP_BATCH", True))
+    if ph in {"val", "valid", "validation"}:
+        return env_bool("ENN_OOM_SKIP_VAL", env_bool("ENN_OOM_SKIP_BATCH", True))
+    return env_bool("ENN_OOM_SKIP_BATCH", True)
