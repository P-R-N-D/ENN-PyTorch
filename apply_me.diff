+@dataclass(frozen=True, slots=True)
+class ModuleRef:
+    module: nn.Module
+    name: str | None = None
+
+
+@dataclass(frozen=True, slots=True)
+class OwnedModule:
+    module: nn.Module
+    name: str | None = None
+
+
+class _MeanPool(nn.Module):
+    def __init__(self, dim: int = 1, keepdim: bool = False) -> None:
+        super().__init__()
+        self.dim = int(dim)
+        self.keepdim = bool(keepdim)
+
+    def forward(self, x: torch.Tensor) -> torch.Tensor:
+        return x.mean(dim=self.dim, keepdim=self.keepdim)
+
+
+class SubgraphModule(nn.Module):
+    def __init__(
+        self,
+        steps: Sequence[object],
+        *args: Any,
+        out_shape: Sequence[int] | None = None,
+        name: str | None = None,
+    ) -> None:
+        super().__init__()
+        self._name = str(name or "subgraph")
+        self._out_shape = tuple(int(x) for x in out_shape) if out_shape is not None else None
+        self._owned = nn.ModuleList()
+
+        compiled_steps: list[tuple[str, object]] = []
+        for step in steps:
+            if isinstance(step, ModuleRef):
+                compiled_steps.append(("ref", weakref.ref(step.module)))
+                continue
+            if isinstance(step, OwnedModule):
+                self._owned.append(step.module)
+                compiled_steps.append(("owned", len(self._owned) - 1))
+                continue
+            if isinstance(step, nn.Module):
+                compiled_steps.append(("ref", weakref.ref(step)))
+                continue
+            if callable(step):
+                compiled_steps.append(("fn", step))
+                continue
+            raise TypeError(f"Unsupported SubgraphModule step: {type(step)!r}")
+        if not compiled_steps:
+            raise ValueError("SubgraphModule requires at least one step.")
+        self._steps = compiled_steps
+
+    @staticmethod
+    def ref(module: nn.Module, *args: Any, name: str | None = None) -> ModuleRef:
+        return ModuleRef(module=module, name=name)
+
+    @staticmethod
+    def own(module: nn.Module, *args: Any, name: str | None = None) -> OwnedModule:
+        return OwnedModule(module=module, name=name)
+
+    @staticmethod
+    def mean(dim: int = 1, *args: Any, keepdim: bool = False) -> OwnedModule:
+        return OwnedModule(module=_MeanPool(dim=int(dim), keepdim=bool(keepdim)), name="mean")
+
+    def forward(self, x: torch.Tensor) -> torch.Tensor:
+        y: torch.Tensor = x
+        for kind, payload in self._steps:
+            if kind == "ref":
+                mod = payload()
+                if mod is None:
+                    raise RuntimeError(
+                        "A shared submodule reference was cleared before SubgraphModule.forward()."
+                    )
+                y = mod(y)
+            elif kind == "owned":
+                y = self._owned[int(payload)](y)
+            else:
+                y = payload(y)
+        if self._out_shape is not None:
+            if y.ndim == 0:
+                raise RuntimeError("Cannot reshape a scalar output in SubgraphModule.")
+            y = y.reshape(y.shape[0], *self._out_shape)
+        return y
+
+    def extra_repr(self) -> str:
+        shape = self._out_shape
+        return f"name={self._name!r}, out_shape={shape!r}, steps={len(self._steps)}"
+
+    def __getstate__(self) -> dict[str, object]:
+        state = super().__getstate__()
+        steps = state.get("_steps", [])
+        sanitized: list[tuple[str, object]] = []
+        if isinstance(steps, list):
+            for kind, payload in steps:
+                if kind == "ref":
+                    sanitized.append((kind, None))
+                else:
+                    sanitized.append((kind, payload))
+            state["_steps"] = sanitized
+        return state
+
