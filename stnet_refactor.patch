-    @classmethod
-    def _qat_has_wrappers(cls: object, model: nn.Module) -> bool:
-        fq_lin = cls.FakeQuantizedLinear
-        fq_emb = cls.FakeQuantizedEmbedding
-        for m in model.modules():
