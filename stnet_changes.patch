+        self.register_buffer("affine_b", torch.zeros(1, dtype=torch.float64))
+        self.register_buffer("pw_x", torch.empty(0, dtype=torch.float64))
+        self.register_buffer("pw_y", torch.empty(0, dtype=torch.float64))
