+def _infer_module_device(module: nn.Module, fallback: torch.device) -> torch.device:
+    """Best-effort device inference that follows .to() / DDP moves."""
+    try:
+        p0 = next(module.parameters(), None)
+        if p0 is not None:
+            return p0.device
+    except Exception:
+        pass
+    try:
+        b0 = next(module.buffers(), None)
+        if b0 is not None:
+            return b0.device
+    except Exception:
+        pass
+    return fallback
