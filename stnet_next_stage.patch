-def stochastic_depth_schedule(drop_path: float, depth: int) -> List[float]:
-    if depth <= 0:
-        return []
-    if drop_path <= 0.0:
-        return [0.0 for _ in range(depth)]
-    if depth == 1:
-        return [float(drop_path)]
-    step = float(drop_path) / float(depth - 1)
-    return [float(i * step) for i in range(depth)]
