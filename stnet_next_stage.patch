+                    _orig = self.processor.perception
+                    _compiled = compile(
+                        _orig,
+                        mode=compile_mode_arg,
+                        fullgraph=False,
+                        dynamic=compile_dynamic,
+                        backend="inductor",
+                        disable=False,
+                        **compile_kwargs,
