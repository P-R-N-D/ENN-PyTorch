+            if compile_heavy_submodules:
+                try:
+                    _orig = self.processor.temporal_net
+                    _compiled = compile(
+                        _orig,
+                        mode=compile_mode_arg,
+                        fullgraph=False,
+                        dynamic=compile_dynamic,
+                        backend="inductor",
+                        disable=False,
+                        **compile_kwargs,
