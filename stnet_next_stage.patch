+    def _get_mask(self, L: int, device: torch.device) -> torch.Tensor:
+        if int(L) > _DILATED_MASK_CACHE_MAX_L:
+            return _get_dilated_mask(
+                int(L),
+                dilation=self.dilation,
+                window_size=self.window_size,
+                causal=self.causal,
+                device=device,
+            )
