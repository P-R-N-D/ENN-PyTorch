-def _estimate_flops_msr(
-    batch: int,
-    seq_len: int,
-    *args: Any,
-    num_heads: int,
-    head_dim: int,
-    use_gate: bool,
-    **kwargs: Any,
-) -> float:
-    if batch <= 0 or seq_len <= 0 or num_heads <= 0 or head_dim <= 0:
-        return 0.0
-    attn = float(batch) * float(seq_len) * float(num_heads) * float(head_dim)
