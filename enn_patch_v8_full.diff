+class Perceiver(nn.Module):
+    """Perceiver-style set fusion block.
+
+    Maps an *unordered* token set of shape (B, N, D) into a fixed-size latent
+    array (B, K, D) via cross-attention (Resampler) and latent self-attention.
+
+    This is intended to be used as the Fuser core to keep
+    complexity ~O(K * N) instead of O(N^2) when N (number of views/tokens)
+    grows.
+    """
+
+    def __init__(
+        self: Self,
+        d_model: int,
+        nhead: int,
+        num_latents: int,
+        depth: int,
+        *args: Any,
+        self_attn_layers: int = 1,
+        mlp_ratio: float = 4.0,
+        dropout: float = 0.0,
+        drop_path: float = 0.0,
+        norm_type: str = "layernorm",
+        **kwargs: Any,
+    ) -> None:
+        super().__init__()
+        del args, kwargs
+        self.d_model = int(d_model)
+        self.nhead = int(nhead)
+        self.num_latents = max(1, int(num_latents))
+        self.depth = max(1, int(depth))
+        self.self_attn_layers = max(0, int(self_attn_layers))
+        self.norm_type = str(norm_type)
+
+        # Learned latent queries (K, D)
+        self.latents = nn.Parameter(torch.randn(self.num_latents, self.d_model) * 0.02)
+
+        total_layers = int(self.depth) * (1 + int(self.self_attn_layers))
+        drops = stochastic_depth_schedule(float(drop_path), total_layers)
+        dp_it = iter(drops)
+
+        self.cross = nn.ModuleList(
+            [
+                Resampler(
+                    d_model=self.d_model,
+                    nhead=self.nhead,
+                    dropout=float(dropout),
+                    mlp_ratio=float(mlp_ratio),
+                    drop_path=float(next(dp_it, 0.0)),
+                    norm_type=str(norm_type),
