+def _sanitize_exported_program(exported: object) -> object:
+    """Remove non-serializable / dead nodes from an ExportedProgram in-place.
+
+    PyTorch may insert a call to torch._functorch.predispatch.lazy_load_decompositions
+    as a dead node (0 users). torch.export.save cannot serialize that target.
+    """
+    gm = getattr(exported, "graph_module", None)
+    g = getattr(gm, "graph", None) if gm is not None else None
+    if g is None:
+        return exported
+
+    # 1) Try generic dead-code elimination
+    with contextlib.suppress(Exception):
+        g.eliminate_dead_code()
+
+    # 2) Explicitly remove lazy_load_decompositions nodes (often 0-user)
+    for node in list(getattr(g, "nodes", ())):
