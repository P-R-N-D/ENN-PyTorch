diff --git a/enn_torch/core/graph.py b/enn_torch/core/graph.py
--- a/enn_torch/core/graph.py
+++ b/enn_torch/core/graph.py
@@ -241,7 +241,17 @@ def _decorate_compiler_disable(
     kwargs: dict[str, Any] = {}
     if reason is not None:
         kwargs["reason"] = reason
-    kwargs["recursive"] = bool(recursive)
+    # torch.export does not support non-recursive compiler disable.
+    recursive = bool(recursive)
+    if not recursive:
+        recursive = True
+    kwargs["recursive"] = recursive
     for opts in (
         kwargs,
         {k: v for k, v in kwargs.items() if k != "recursive"},
         {k: v for k, v in kwargs.items() if k != "reason"},
         {},
     ):
         try:
             dec = _resolve_compiler_disable()(**opts)
             if callable(dec):
                 return dec
         except TypeError:
             continue
         except Exception:
             break
     return _identity

