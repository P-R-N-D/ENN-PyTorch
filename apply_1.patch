diff --git a/enn_torch/runtime/workflows.py b/enn_torch/runtime/workflows.py
index 7d0a0d0..b0b0b0b 100644
--- a/enn_torch/runtime/workflows.py
+++ b/enn_torch/runtime/workflows.py
@@ -2059,6 +2059,16 @@ def _rewrite_state_dict_key(k: str) -> str:
+    # Common wrappers (DDP/DP) prefix parameters with "module.".
+    # Some checkpoints may also prefix with "model." (DCP-style dict wrappers).
+    if k.startswith("module."):
+        return k[len("module.") :]
+    if k.startswith("model."):
+        return k[len("model.") :]
+
     if k.startswith("m.") and ".module." in k:
         parts = k.split(".")
         if len(parts) >= 4 and parts[1].isdigit() and parts[2] == "module":
             return ".".join(parts[3:])
     return k
