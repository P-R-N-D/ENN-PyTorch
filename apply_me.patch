@@
+import logging
+_LOGGER = logging.getLogger(__name__)
+
+# One in-flight checkpoint globally, enforced by a lock file.
+# This is intentionally independent from pruning/deletion success.
+_INFLIGHT_LOCK_NAME = ".inflight.lock"
+_INFLIGHT_LOCK_TTL_SEC = int(os.environ.get("ENN_DCP_INFLIGHT_LOCK_TTL_SEC", "21600"))  # 6h
+
+def _atomic_create_json(path, payload: dict) -> bool:
+    \"\"\"Atomic create for cross-process safety (works with no-GIL 3.13t/3.14t too).\"\"\"
+    try:
+        path.parent.mkdir(parents=True, exist_ok=True)
+    except Exception:
+        pass
+    try:
+        with open(path, "x", encoding="utf-8") as f:
+            json.dump(payload, f)
+        return True
+    except FileExistsError:
+        return False
+    except Exception:
+        # best-effort cleanup if partially created
+        with contextlib.suppress(Exception):
+            if path.exists():
+                path.unlink()
+        return False
+
+def _safe_rmtree(path) -> None:
+    \"\"\"Resilient deletion: rmtree -> rename to delete_pending -> rmtree.\"\"\"
+    import shutil
+    shutil.rmtree(path, ignore_errors=True)
+    try:
+        if not path.exists():
+            return
+    except Exception:
+        return
+    ts = int(time.time())
+    dp = path.with_name(f\"{path.name}.delete_pending.{ts}\")
+    with contextlib.suppress(Exception):
+        path.rename(dp)
+    shutil.rmtree(dp, ignore_errors=True)
+
+def _cleanup_delete_pending(root) -> None:
+    with contextlib.suppress(Exception):
+        for p in root.glob(\"*.delete_pending.*\"):
+            _safe_rmtree(p)
