+def _coerce_dcp_keys(state: object) -> object:
+    """Normalize/clean state_dict keys before DCP save.
+
+    Some module types may emit non-tensor/auxiliary keys that DCP cannot
+    roundtrip robustly (e.g. module extra_state). This helper mirrors the
+    in-training behavior and removes known-problematic keys recursively.
+    """
+
+    if isinstance(state, dict):
+        keys_to_drop: list[object] = []
+        for key, value in state.items():
+            key_str = str(key)
+            if (
+                key_str.endswith("._extra_state")
+                or key_str.endswith("_extra_state")
+                or key_str.endswith("output_baked_flag")
+            ):
+                keys_to_drop.append(key)
+                continue
+            state[key] = _coerce_dcp_keys(value)
+        for key in keys_to_drop:
+            with contextlib.suppress(Exception):
+                state.pop(key, None)
+    return state
+
