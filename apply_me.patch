+    def poll(self) -> None:
+        """Progress async checkpointing without blocking training."""
+        # If upload finished, finalize + cleanup.
+        if self._resp is not None:
+            fut = getattr(self._resp, "upload_completion", None)
+            if fut is not None and getattr(fut, "done", lambda: False)():
+                # Consume exceptions (surface in logs) but don't crash training unless strict.
+                strict = bool(env_bool("ENN_DCP_RECIPE_STRICT", default=False))
+                try:
