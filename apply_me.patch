+    def _background_dcp_enabled(self) -> bool:
+        # Safety: DCP in background thread is only enabled by default for single-rank runs.
+        # (Multi-rank background collectives can deadlock if training collectives overlap.)
+        try:
+            world = int(getattr(self, "_world", 1) or 1)
+        except Exception:
+            world = 1
+        default_bg = world <= 1
+        enabled = bool(env_bool("ENN_DCP_BACKGROUND", default=default_bg))
+        return bool(enabled and world <= 1)
